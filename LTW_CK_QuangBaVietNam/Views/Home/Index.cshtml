<script>
    // Breadcrumb scroll effect
    const breadcrumbWrapper = document.querySelector('.breadcrumb-wrapper');
    let lastScrollTop = 0;

    window.addEventListener('scroll', function () {
        const scrollTop = window.pageYOffset || document.documentElement.scrollTop;

        if (breadcrumbWrapper) {
            if (scrollTop > 100) {
                breadcrumbWrapper.classList.add('scrolled');
            } else {
                breadcrumbWrapper.classList.remove('scrolled');
            }
        }

        lastScrollTop = scrollTop;
    });

    // ===== CATEGORY CARDS - CINEMATIC PANELS =====
    const categoryCards = document.querySelectorAll('.category-card');
    const categorySection = document.querySelector('.category-section');

    categoryCards.forEach(card => {
        card.addEventListener('mouseenter', function () {
            const category = this.getAttribute('data-category');
            if (categorySection) {
                // Remove all light classes
                categorySection.classList.remove('light-nature', 'light-culture', 'light-cuisine', 'light-urban');
                // Add the appropriate light class
                categorySection.classList.add(`light-${category}`);
            }

            // Dim other cards
            categoryCards.forEach(c => {
                if (c !== this) {
                    c.style.opacity = '0.65';
                    c.style.filter = 'blur(2px)';
                }
            });
            this.style.opacity = '1';
            this.style.filter = 'blur(0)';
        });

        card.addEventListener('mouseleave', function () {
            // Reset all cards
            categoryCards.forEach(c => {
                c.style.opacity = '1';
                c.style.filter = 'blur(0)';
            });
            // Reset background
            if (categorySection) {
                categorySection.classList.remove('light-nature', 'light-culture', 'light-cuisine', 'light-urban');
            }
        });

        // Parallax effect on background image
        card.addEventListener('mousemove', function (e) {
            const rect = this.getBoundingClientRect();
            const x = (e.clientX - rect.left) / rect.width;
            const y = (e.clientY - rect.top) / rect.height;

            const xOffset = (x - 0.5) * 15;
            const yOffset = (y - 0.5) * 15;

            this.style.setProperty('--parallax-x', `${xOffset}px`);
            this.style.setProperty('--parallax-y', `${yOffset}px`);
        });

        card.addEventListener('mouseleave', function () {
            this.style.setProperty('--parallax-x', '0px');
            this.style.setProperty('--parallax-y', '0px');
        });

        // Click interaction
        card.addEventListener('click', function () {
            const category = this.getAttribute('data-category');
            console.log('Exploring category:', category);
            // Could navigate to category page or open modal
        });
    });

    // Filter buttons interaction
    document.querySelectorAll('.filter-btn').forEach(btn => {
        btn.addEventListener('click', function () {
            document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
            this.classList.add('active');
        });
    });

    // ===== FAVORITE HEART - CINEMATIC EXPERIENCE =====
    document.querySelectorAll('.favorite-btn').forEach(btn => {
        const card = btn.closest('.destination-card');
        const titleElement = card ? card.querySelector('.card-title') : null;
        const title = titleElement ? titleElement.textContent : '';

        btn.addEventListener('click', function (e) {
            e.preventDefault();
            e.stopPropagation();

            const icon = this.querySelector('i');
            if (!icon) return;

            const isAdding = icon.classList.contains('bi-heart');

            if (isAdding) {
                // ===== ADD TO FAVORITES - CINEMATIC EFFECT =====

                // 1. Pop animation on heart
                icon.classList.add('pop-animate');
                icon.classList.remove('bi-heart');
                icon.classList.add('bi-heart-fill');

                // 2. Glow wave on card
                if (card) {
                    card.classList.add('favorite-glow');
                    setTimeout(() => card.classList.remove('favorite-glow'), 600);
                }

                // 3. Particle burst effect
                createParticleBurst(btn, 8);

                // 4. Toast notification
                showFavoriteToast(`Đã thêm "${title}" vào hành trình`, true);

                // 5. Save to localStorage
                saveFavorite(title, true);
            } else {
                // ===== REMOVE FROM FAVORITES - SMOOTH TRANSITION =====

                icon.classList.remove('pop-animate');
                icon.classList.remove('bi-heart-fill');
                icon.classList.add('bi-heart');

                // Subtle fade-out animation
                btn.style.animation = 'none';
                setTimeout(() => {
                    btn.style.animation = '';
                }, 10);

                showFavoriteToast(`Đã xóa "${title}" khỏi hành trình`, false);
                saveFavorite(title, false);
            }

            // Remove animation class after it completes
            setTimeout(() => icon.classList.remove('pop-animate'), 600);
        });

        // Load favorites from localStorage on page load
        if (title && localStorage.getItem(`favorite_${title}`)) {
            const icon = btn.querySelector('i');
            if (icon) {
                icon.classList.remove('bi-heart');
                icon.classList.add('bi-heart-fill');
            }
        }
    });

    // Create particle burst effect
    function createParticleBurst(button, count = 8) {
        const rect = button.getBoundingClientRect();
        const startX = rect.left + rect.width / 2;
        const startY = rect.top + rect.height / 2;

        for (let i = 0; i < count; i++) {
            const angle = (i / count) * Math.PI * 2;
            const distance = 60 + Math.random() * 40;
            const endX = Math.cos(angle) * distance;
            const endY = Math.sin(angle) * distance;

            const particle = document.createElement('div');
            particle.className = 'favorite-particle';
            particle.innerHTML = '♥';
            particle.style.left = startX + 'px';
            particle.style.top = startY + 'px';
            particle.style.setProperty('--tx', endX.toString() + 'px');
            particle.style.setProperty('--ty', endY.toString() + 'px');
            particle.style.color = '#dc2626';
            particle.style.opacity = '0.8';

            document.body.appendChild(particle);

            setTimeout(() => particle.remove(), 800);
        }
    }

    // Show toast notification
    function showFavoriteToast(message, isAdding = true) {
        // Remove existing toast if any
        const existingToast = document.querySelector('.favorite-toast');
        if (existingToast) existingToast.remove();

        const toast = document.createElement('div');
        toast.className = 'favorite-toast';

        // Add 'remove' class if unfavoriting
        if (!isAdding) {
            toast.classList.add('remove');
        }

        toast.innerHTML = `
            <i class="bi ${isAdding ? 'bi-heart-fill' : 'bi-heart'}"></i>
            <span>${message}</span>
        `;

        document.body.appendChild(toast);

        // Auto-remove after 3 seconds
        setTimeout(() => {
            toast.style.animation = 'toastSlideIn 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) reverse forwards';
            setTimeout(() => toast.remove(), 400);
        }, 3000);
    }

    // Save/remove favorite to localStorage
    function saveFavorite(title, isFavorited) {
        const key = `favorite_${title}`;
        if (isFavorited) {
            localStorage.setItem(key, JSON.stringify({ title, addedAt: new Date().toISOString() }));
        } else {
            localStorage.removeItem(key);
        }
    }

    // Smooth scroll for anchor links
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        const anchorElement = anchor;
        anchor.addEventListener('click', function (e) {
            e.preventDefault();
            const href = this.getAttribute('href');
            if (href) {
                const target = document.querySelector(href);
                if (target) {
                    const headerOffset = 160;
                    const elementPosition = target.getBoundingClientRect().top;
                    const offsetPosition = elementPosition + window.pageYOffset - headerOffset;

                    window.scrollTo({
                        top: offsetPosition,
                        behavior: 'smooth'
                    });
                }
            }
        });
    });
</script>