
@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    :root {
        --deep-slate: #1e293b;
        --slate: #334155;
        --sky-blue: #0EA5E9;
        --sky-light: #38BDF8;
        --slate-light: #cbd5e1;
        --white: #ffffff;
        --spacing-2: 0.5rem;
        --spacing-3: 0.75rem;
        --spacing-4: 1rem;
        --spacing-6: 1.5rem;
        --spacing-8: 2rem;
        --spacing-12: 3rem;
        --spacing-16: 4rem;
        --spacing-24: 6rem;
    }

    /* HERO BANNER */
    .hero-banner {
        position: relative;
        height: 680px;
        background: linear-gradient(135deg, rgba(30, 41, 59, 0.85), rgba(14, 165, 233, 0.65)), url('https://images.unsplash.com/photo-1583417319070-4a69db38a482?w=1920&q=80') center/cover;
        background-attachment: fixed;
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--white);
        text-align: center;
        /*margin-bottom: var(--spacing-16);*/
        overflow: hidden;
    }

        .hero-banner::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: radial-gradient(circle at 30% 50%, rgba(14, 165, 233, 0.3), transparent 70%);
        }

    .hero-content {
        position: relative;
        z-index: 2;
        padding: 0 var(--spacing-6);
    }

        .hero-content h1 {
            font-size: 4rem;
            font-weight: 800;
            margin-bottom: var(--spacing-6);
            text-shadow: 0 4px 24px rgba(0, 0, 0, 0.4);
            line-height: 1.15;
        }

        .hero-content p {
            font-size: 1.5rem;
            margin-bottom: var(--spacing-12);
            opacity: 0.95;
            text-shadow: 0 2px 12px rgba(0, 0, 0, 0.3);
        }

    .hero-search {
        background: rgba(255, 255, 255, 0.98);
        backdrop-filter: blur(24px);
        border-radius: 999px;
        padding: var(--spacing-3);
        max-width: 700px;
        margin: 0 auto;
        display: flex;
        gap: var(--spacing-3);
        box-shadow: 0 12px 56px rgba(0, 0, 0, 0.3);
        border: 1px solid rgba(255, 255, 255, 0.5);
    }

        .hero-search input {
            flex: 1;
            border: none;
            padding: var(--spacing-4) var(--spacing-6);
            border-radius: 999px;
            font-size: 1.0625rem;
            background: transparent;
            color: var(--deep-slate);
        }

            .hero-search input:focus {
                outline: none;
            }

            .hero-search input::placeholder {
                color: #64748b;
            }

    .btn-primary-custom {
        background: linear-gradient(135deg, var(--sky-blue), var(--sky-light));
        color: var(--white);
        border: none;
        padding: var(--spacing-4) var(--spacing-8);
        border-radius: 999px;
        font-weight: 700;
        transition: all 0.3s ease;
        box-shadow: 0 4px 20px rgba(14, 165, 233, 0.4);
        white-space: nowrap;
        font-size: 1rem;
        display: inline-flex;
        align-items: center;
        gap: var(--spacing-2);
        text-decoration: none;
        cursor: pointer;
    }

        .btn-primary-custom:hover,
        .btn-primary-custom:focus {
            transform: translateY(-3px);
            box-shadow: 0 8px 32px rgba(14, 165, 233, 0.5);
            color: var(--white);
            text-decoration: none;
        }

        .btn-primary-custom:active {
            transform: translateY(-1px);
        }

    /* STICKY FILTER BAR */
    .filter-bar {
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(20px);
        padding: var(--spacing-6) 0;
        box-shadow: 0 4px 28px rgba(30, 41, 59, 0.08);
        position: sticky;
        top: 111px;
        z-index: 1020;
        margin-bottom: var(--spacing-16);
        border-bottom: 1px solid rgba(14, 165, 233, 0.15);
    }

        .filter-bar .filter-btn {
            padding: var(--spacing-3) var(--spacing-6);
            border: 2px solid rgba(14, 165, 233, 0.25);
            border-radius: 999px;
            background: white;
            color: var(--slate);
            margin-right: var(--spacing-3);
            margin-bottom: var(--spacing-2);
            transition: all 0.3s ease;
            font-weight: 600;
            font-size: 0.9375rem;
            box-shadow: 0 2px 8px rgba(30, 41, 59, 0.06);
        }

            .filter-bar .filter-btn:hover {
                border-color: var(--sky-blue);
                background: rgba(14, 165, 233, 0.08);
                color: var(--deep-slate);
                transform: translateY(-2px);
                box-shadow: 0 4px 16px rgba(14, 165, 233, 0.2);
            }

            .filter-bar .filter-btn.active {
                border-color: transparent;
                background: linear-gradient(135deg, var(--sky-blue), var(--sky-light));
                color: var(--white);
                box-shadow: 0 4px 20px rgba(14, 165, 233, 0.35);
            }

    /* CATEGORY CARDS - CINEMATIC PANELS (NO ICONS) */
    .category-section {
        margin-bottom: var(--spacing-24);
        position: relative;
    }

    .category-grid {
        display: flex;
        gap: var(--spacing-6);
        margin-top: var(--spacing-12);
        align-items: stretch;
    }

    .category-card {
        position: relative;
        flex: 1;
        border-radius: 28px;
        overflow: hidden;
        cursor: pointer;
        transition: flex 0.45s cubic-bezier(0.34, 1.56, 0.64, 1), transform 0.45s cubic-bezier(0.34, 1.56, 0.64, 1);
        min-height: 320px;
        border: 2px solid rgba(255, 255, 255, 0.12);
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        justify-content: flex-end;
        padding: var(--spacing-8);
        box-shadow: 0 12px 48px rgba(0, 0, 0, 0.15);
        text-align: right;
        will-change: flex, transform, box-shadow;
    }

        /* Hover state - expand to 3-4x size */
        .category-card:hover {
            flex: 3.5;
            transform: translateY(-8px);
        }

        /* Background image - full screen cinematic */
        .category-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-size: 110%;
            background-position: center;
            background-repeat: no-repeat;
            opacity: 0.7;
            transition: all 0.7s ease;
            z-index: 0;
            will-change: background-size, opacity;
            filter: brightness(0.9) contrast(1.1);
        }

        /* Category-specific cinematic backgrounds */
        .category-card[data-category="nature"]::before {
            background-image: url('https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=800&q=90');
            background-position: center 40%;
        }

        .category-card[data-category="culture"]::before {
            background-image: url('https://images.unsplash.com/photo-1559592413-7cec4d0cae2b?w=800&q=90');
            background-position: center 30%;
        }

        .category-card[data-category="cuisine"]::before {
            background-image: url('https://images.unsplash.com/photo-1555939594-58d7cb561e1f?w=800&q=90');
            background-position: center 50%;
        }

        .category-card[data-category="urban"]::before {
            background-image: url('https://images.unsplash.com/photo-1480714378408-67cf0d13bc1b?w=800&q=90');
            background-position: center 30%;
        }

        .category-card:hover::before {
            background-size: 120%;
            opacity: 0.85;
            filter: brightness(1) contrast(1.15);
        }

        /* Glass overlay gradient - makes text readable */
        .category-card::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 100%;
            background: linear-gradient( to top, rgba(15, 23, 42, 0.85) 0%, rgba(15, 23, 42, 0.4) 50%, transparent 100% );
            z-index: 1;
            transition: all 0.4s ease;
        }

        /* Darken other cards when one is hovered */
        .category-card:not(:hover)::after {
            background: linear-gradient( to top, rgba(15, 23, 42, 0.92) 0%, rgba(15, 23, 42, 0.55) 50%, transparent 100% );
            filter: saturate(0.85);
        }

        /* Color overlay per category - only visible on hover */
        .category-card[data-category="nature"]:hover::after {
            background: linear-gradient( to top, rgba(34, 197, 94, 0.35), rgba(34, 197, 94, 0.08) 30%, transparent 100% );
        }

        .category-card[data-category="culture"]:hover::after {
            background: linear-gradient( to top, rgba(251, 146, 60, 0.4), rgba(251, 146, 60, 0.12) 30%, transparent 100% );
        }

        .category-card[data-category="cuisine"]:hover::after {
            background: linear-gradient( to top, rgba(234, 88, 12, 0.45), rgba(234, 88, 12, 0.12) 30%, transparent 100% );
        }

        .category-card[data-category="urban"]:hover::after {
            background: linear-gradient( to top, rgba(59, 130, 246, 0.35), rgba(59, 130, 246, 0.08) 30%, transparent 100% );
        }

    /* Content - Title & Description */
    .category-card-content {
        position: relative;
        z-index: 2;
        width: 100%;
        transition: all 0.5s ease;
        opacity: 0.8;
    }

    .category-card:hover .category-card-content {
        opacity: 1;
    }

    .category-card h5 {
        font-weight: 900;
        color: var(--white);
        margin: 0 0 var(--spacing-2) 0;
        font-size: 1.5rem;
        letter-spacing: 2px;
        text-transform: uppercase;
        transition: all 0.5s ease;
        text-shadow: 0 4px 16px rgba(0, 0, 0, 0.4);
        line-height: 1.2;
    }

    .category-card:hover h5 {
        font-size: 2rem;
        transform: translateY(-8px);
        text-shadow: 0 6px 24px rgba(0, 0, 0, 0.5);
    }

    .category-card p {
        margin: 0;
        color: rgba(255, 255, 255, 0.85);
        font-size: 0.9375rem;
        line-height: 1.5;
        font-weight: 400;
        opacity: 0.6;
        transition: all 0.5s ease;
        text-shadow: 0 2px 10px rgba(0, 0, 0, 0.3);
        max-width: 200px;
        text-align: right;
    }

    .category-card:hover p {
        opacity: 1;
        font-size: 1rem;
        transform: translateY(-4px);
    }

    /* Hover glow effect - colored light emanates */
    .category-card[data-category="nature"]:hover {
        box-shadow: 0 24px 64px rgba(34, 197, 94, 0.35), 0 0 50px rgba(34, 197, 94, 0.15);
        border-color: rgba(34, 197, 94, 0.4);
    }

    .category-card[data-category="culture"]:hover {
        box-shadow: 0 24px 64px rgba(251, 146, 60, 0.35), 0 0 50px rgba(251, 146, 60, 0.15);
        border-color: rgba(251, 146, 60, 0.4);
    }

    .category-card[data-category="cuisine"]:hover {
        box-shadow: 0 24px 64px rgba(234, 88, 12, 0.35), 0 0 50px rgba(234, 88, 12, 0.15);
        border-color: rgba(234, 88, 12, 0.4);
    }

    .category-card[data-category="urban"]:hover {
        box-shadow: 0 24px 64px rgba(59, 130, 246, 0.35), 0 0 50px rgba(59, 130, 246, 0.15);
        border-color: rgba(59, 130, 246, 0.4);
    }

    /* Accent line - appears on hover */
    .category-card .accent-line {
        position: absolute;
        top: var(--spacing-8);
        right: var(--spacing-8);
        width: 0;
        height: 3px;
        background: linear-gradient(90deg, transparent, currentColor);
        border-radius: 2px;
        transition: width 0.6s ease;
        z-index: 2;
    }

    .category-card[data-category="nature"] .accent-line {
        background: linear-gradient(90deg, transparent, #22c55e);
    }

    .category-card[data-category="culture"] .accent-line {
        background: linear-gradient(90deg, transparent, #fb923c);
    }

    .category-card[data-category="cuisine"] .accent-line {
        background: linear-gradient(90deg, transparent, #ea580c);
    }

    .category-card[data-category="urban"] .accent-line {
        background: linear-gradient(90deg, transparent, #3b82f6);
    }

    .category-card:hover .accent-line {
        width: 56px;
    }

    /* Section background lighting */
    .category-section.light-nature {
        background: radial-gradient(ellipse at center, rgba(34, 197, 94, 0.08), transparent 85%);
    }

    .category-section.light-culture {
        background: radial-gradient(ellipse at center, rgba(251, 146, 60, 0.08), transparent 85%);
    }

    .category-section.light-cuisine {
        background: radial-gradient(ellipse at center, rgba(234, 88, 12, 0.08), transparent 85%);
    }

    .category-section.light-urban {
        background: radial-gradient(ellipse at center, rgba(59, 130, 246, 0.08), transparent 85%);
    }

    /* Responsive */
    @@media (max-width: 1200px) {
        .category-grid {
            grid-template-columns: 1fr 1fr 1fr 1fr;
            gap: var(--spacing-6);
        }

        .category-card {
            height: 340px;
        }

            .category-card h5 {
                font-size: 1.375rem;
            }

            .category-card p {
                font-size: 0.9375rem;
            }
    }

    @@media (max-width: 768px) {
        .category-grid {
            grid-template-columns: 1fr 1fr;
            gap: var(--spacing-4);
        }

        .category-card {
            height: 300px;
            padding: var(--spacing-8);
        }

            .category-card h5 {
                font-size: 1.25rem;
                letter-spacing: 1px;
            }

            .category-card p {
                font-size: 0.875rem;
                max-width: 180px;
            }

            .category-card .accent-line {
                top: var(--spacing-6);
                right: var(--spacing-6);
            }
    }

    @@media (max-width: 480px) {
        .category-grid {
            grid-template-columns: 1fr;
            gap: var(--spacing-4);
        }

        .category-card {
            height: 240px;
            padding: var(--spacing-6);
        }

            .category-card h5 {
                font-size: 1.125rem;
            }

            .category-card p {
                font-size: 0.8125rem;
                max-width: 150px;
            }
    }

    /* DESTINATION CARDS - INSPIRATION CARDS (NO PRICING/RATING) */
    .destination-card {
        border-radius: 24px;
        overflow: hidden;
        box-shadow: 0 8px 36px rgba(30, 41, 59, 0.12);
        transition: all 0.4s ease;
        background: white;
        height: 100%;
        border: 2px solid transparent;
        display: flex;
        flex-direction: column;
    }

        .destination-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 24px 64px rgba(14, 165, 233, 0.25);
            border-color: rgba(14, 165, 233, 0.3);
        }

        .destination-card .card-img-wrapper {
            position: relative;
            overflow: hidden;
            height: 280px;
            flex-shrink: 0;
        }

            .destination-card .card-img-wrapper img {
                width: 100%;
                height: 100%;
                object-fit: cover;
                transition: transform 0.6s ease;
                display: block;
            }

        .destination-card:hover .card-img-wrapper img {
            transform: scale(1.08);
        }

        .destination-card .favorite-btn {
            position: absolute;
            top: var(--spacing-4);
            right: var(--spacing-4);
            width: 48px;
            height: 48px;
            background: rgba(255, 255, 255, 0.96);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: none;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
            z-index: 3;
        }

            .destination-card .favorite-btn:hover {
                background: rgba(255, 255, 255, 1);
                transform: scale(1.12);
                box-shadow: 0 8px 28px rgba(14, 165, 233, 0.25);
            }

            .destination-card .favorite-btn i {
                font-size: 1.25rem;
                color: rgba(14, 165, 233, 0.6);
                transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
            }

        .destination-card:hover .favorite-btn i {
            color: var(--sky-blue);
        }

        /* Active state - filled heart */
        .destination-card .favorite-btn i.bi-heart-fill {
            color: #dc2626;
            filter: drop-shadow(0 0 8px rgba(220, 38, 38, 0.5));
        }

        /* Pop animation on click */
        .destination-card .favorite-btn i.pop-animate {
            animation: heartPop 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
        }

    @@keyframes heartPop {
        0% {
            transform: scale(1);
            opacity: 1;
        }

        50% {
            transform: scale(1.4);
        }

        100% {
            transform: scale(1.25);
            opacity: 1;
        }
    }

    /* Particle effect - burst out from heart */
    .favorite-particle {
        position: fixed;
        pointer-events: none;
        font-size: 1.5rem;
        animation: particleBurst 0.8s ease-out forwards;
        z-index: 9999;
    }

    @@keyframes particleBurst {
        0% {
            transform: translate(0, 0) scale(1);
            opacity: 1;
        }

        100% {
            transform: translate(var(--tx), var(--ty))) scale(0);
            opacity: 0;
        }
    }

    /* Glow wave effect on video card */
    .destination-card.favorite-glow {
        animation: cardFavoriteGlow 0.6s ease-out forwards;
    }

    @@keyframes cardFavoriteGlow {
        0% {
            box-shadow: 0 8px 36px rgba(30, 41, 59, 0.12), 0 0 0 0 rgba(220, 38, 38, 0.5);
        }

        50% {
            box-shadow: 0 8px 36px rgba(30, 41, 59, 0.12), 0 0 0 20px rgba(220, 38, 38, 0);
        }

        100% {
            box-shadow: 0 8px 36px rgba(30, 41, 59, 0.12), 0 0 0 0 rgba(220, 38, 38, 0);
        }
    }

    /* Toast notification style */
    .favorite-toast {
        position: fixed;
        bottom: 32px;
        right: 32px;
        background: linear-gradient(135deg, rgba(220, 38, 38, 0.95), rgba(200, 38, 38, 0.95));
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        color: white;
        padding: 16px 24px;
        border-radius: 12px;
        font-size: 0.9375rem;
        font-weight: 600;
        box-shadow: 0 12px 40px rgba(220, 38, 38, 0.3);
        border: 1px solid rgba(255, 255, 255, 0.2);
        display: flex;
        align-items: center;
        gap: 12px;
        animation: toastSlideIn 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
        z-index: 10000;
    }

        /* Remove/Gray state */
        .favorite-toast.remove {
            background: linear-gradient(135deg, rgba(100, 116, 139, 0.95), rgba(90, 104, 123, 0.95));
            box-shadow: 0 12px 40px rgba(100, 116, 139, 0.3);
            border: 1px solid rgba(255, 255, 255, 0.15);
        }

        .favorite-toast i {
            font-size: 1.25rem;
            animation: toastIconBounce 0.6s ease-out;
        }

    @@keyframes toastSlideIn {
        from {
            transform: translateX(400px);
            opacity: 0;
        }

        to {
            transform: translateX(0);
            opacity: 1;
        }
    }

    @@keyframes toastIconBounce {
        0% {
            transform: scale(0);
        }

        50% {
            transform: scale(1.2);
        }

        100% {
            transform: scale(1);
        }
    }

    @@media (max-width: 768px) {
        .favorite-toast {
            bottom: 20px;
            right: 20px;
            padding: 12px 16px;
            font-size: 0.875rem;
        }
    }

    /* Card content - NEW STRUCTURE */
    .destination-card .card-body {
        padding: var(--spacing-6);
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    .destination-card .card-title {
        font-size: 1.5rem;
        font-weight: 800;
        margin-bottom: var(--spacing-2);
        color: var(--deep-slate);
        line-height: 1.2;
        letter-spacing: -0.5px;
    }

    .destination-card .card-location {
        font-size: 0.875rem;
        color: #94a3b8;
        font-weight: 500;
        margin-bottom: var(--spacing-4);
        display: flex;
        align-items: center;
        gap: 0.35rem;
    }

        .destination-card .card-location i {
            font-size: 1rem;
            color: var(--sky-blue);
        }

    /* Inspiration description - KEY NEW ELEMENT */
    .destination-card .card-description {
        color: #64748b;
        font-size: 0.95rem;
        line-height: 1.6;
        margin-bottom: auto;
        font-weight: 400;
        font-style: italic;
        transition: color 0.3s ease;
        quotes: """ """;
    }

    .destination-card:hover .card-description {
        color: var(--sky-blue);
    }

    .destination-card .card-description::before {
        content: """; margin-right: 0.25rem;
        opacity: 0.5;
    }

    .destination-card .card-description::after {
        content: """; margin-left: 0.25rem;
        opacity: 0.5;
    }

    /* Experience badge - REPLACES PRICE/RATING */
    .destination-card .experience-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        margin-top: var(--spacing-4);
        padding: 0.5rem 1rem;
        background: rgba(14, 165, 233, 0.08);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1.5px solid rgba(14, 165, 233, 0.25);
        border-radius: 999px;
        font-size: 0.8125rem;
        font-weight: 600;
        color: var(--sky-blue);
        letter-spacing: 0.5px;
        text-transform: uppercase;
        transition: all 0.3s ease;
        width: fit-content;
    }

    .destination-card:hover .experience-badge {
        background: rgba(14, 165, 233, 0.15);
        border-color: rgba(14, 165, 233, 0.4);
        box-shadow: 0 4px 12px rgba(14, 165, 233, 0.15);
    }

    .destination-card .experience-badge::before {
        content: "✦";
        font-size: 0.7rem;
    }

    /* BLOG CARDS */
    .blog-card {
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(12px);
        border-radius: 24px;
        overflow: hidden;
        box-shadow: 0 4px 24px rgba(30, 41, 59, 0.1);
        display: flex;
        margin-bottom: var(--spacing-6);
        transition: all 0.4s ease;
        border: 2px solid transparent;
    }

        .blog-card:hover {
            transform: translateX(12px);
            box-shadow: 0 12px 40px rgba(14, 165, 233, 0.2);
            border-color: rgba(14, 165, 233, 0.25);
        }

        .blog-card img {
            width: 300px;
            height: 220px;
            object-fit: cover;
            transition: transform 0.5s ease;
        }

        .blog-card:hover img {
            transform: scale(1.1);
        }

        .blog-card .content {
            padding: var(--spacing-6);
            flex: 1;
        }

            .blog-card .content h5 {
                font-weight: 700;
                margin-bottom: var(--spacing-4);
                color: var(--deep-slate);
