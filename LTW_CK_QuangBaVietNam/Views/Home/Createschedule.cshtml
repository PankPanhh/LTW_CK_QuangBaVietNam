@{
    ViewBag.Title = "Createschedule";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    :root {
        --deep-slate: #1e293b;
        --slate: #334155;
        --sky-blue: #0EA5E9;
        --sky-light: #38BDF8;
        --slate-light: #cbd5e1;
        --slate-200: #e2e8f0;
        --amber: #f59e0b;
        --rose: #f43f5e;
        --white: #ffffff;
        --spacing-2: 0.5rem;
        --spacing-3: 0.75rem;
        --spacing-4: 1rem;
        --spacing-6: 1.5rem;
        --spacing-8: 2rem;
        --spacing-12: 3rem;
    }

    /* ========== JOURNEY INITIALIZATION SCREEN ========== */
    .journey-init-container {
        position: relative;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, rgba(248, 250, 252, 0.95), rgba(226, 232, 240, 0.6)), url('https://images.unsplash.com/photo-1488646953014-85cb44e25828?w=1920&q=80') center/cover;
        background-attachment: fixed;
        padding: var(--spacing-8);
    }

        .journey-init-container::before {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(circle at 20% 80%, rgba(14, 165, 233, 0.08), transparent 70%);
            pointer-events: none;
        }

    .journey-init-form {
        position: relative;
        z-index: 2;
        background: var(--white);
        border-radius: 24px;
        box-shadow: 0 20px 60px rgba(30, 41, 59, 0.12);
        padding: var(--spacing-12);
        max-width: 600px;
        width: 100%;
        border: 1px solid rgba(14, 165, 233, 0.1);
        animation: slideInUp 0.6s ease-out;
    }

    @@keyframes slideInUp {
        from {
            opacity: 0;
            transform: translateY(40px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .journey-init-header {
        text-align: center;
        margin-bottom: var(--spacing-12);
    }

        .journey-init-header h1 {
            font-size: 2.5rem;
            font-weight: 800;
            color: var(--deep-slate);
            margin-bottom: var(--spacing-4);
            line-height: 1.2;
        }

        .journey-init-header p {
            font-size: 1rem;
            color: var(--slate);
            margin: 0;
            font-weight: 500;
        }

    .form-group-custom {
        margin-bottom: var(--spacing-8);
    }

        .form-group-custom label {
            display: block;
            font-size: 0.95rem;
            font-weight: 600;
            color: var(--deep-slate);
            margin-bottom: var(--spacing-3);
        }

        .form-group-custom input,
        .form-group-custom select {
            width: 100%;
            padding: var(--spacing-4) var(--spacing-6);
            font-size: 1rem;
            border: 2px solid var(--slate-200);
            border-radius: 12px;
            background: #f8fafc;
            color: var(--deep-slate);
            transition: all 0.3s ease;
            font-family: inherit;
        }

            .form-group-custom input:focus,
            .form-group-custom select:focus {
                outline: none;
                border-color: var(--sky-blue);
                background: var(--white);
                box-shadow: 0 0 0 4px rgba(14, 165, 233, 0.1);
            }

    .date-group {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: var(--spacing-6);
    }

        .date-group .form-group-custom {
            margin-bottom: 0;
        }

        .date-group label {
            display: block;
            font-size: 0.95rem;
            font-weight: 600;
            color: var(--deep-slate);
            margin-bottom: var(--spacing-3);
        }

    /* Suggestions */
    .suggestions-box {
        background: linear-gradient(135deg, rgba(14, 165, 233, 0.05), rgba(248, 250, 252, 0.8));
        border: 1px solid rgba(14, 165, 233, 0.15);
        border-radius: 12px;
        padding: var(--spacing-6);
        margin-bottom: var(--spacing-8);
    }

    .suggestions-label {
        font-size: 0.85rem;
        font-weight: 700;
        color: var(--sky-blue);
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: var(--spacing-3);
    }

    .suggestion-chips {
        display: flex;
        flex-wrap: wrap;
        gap: var(--spacing-3);
    }

    .suggestion-chip {
        background: var(--white);
        border: 1px solid var(--sky-light);
        border-radius: 20px;
        padding: var(--spacing-2) var(--spacing-6);
        font-size: 0.9rem;
        color: var(--sky-blue);
        cursor: pointer;
        transition: all 0.3s ease;
        font-weight: 500;
    }

        .suggestion-chip:hover {
            background: var(--sky-light);
            color: var(--white);
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(14, 165, 233, 0.25);
        }

    /* Privacy Mode */
    .privacy-selector {
        display: flex;
        gap: var(--spacing-4);
    }

    .privacy-option {
        flex: 1;
        position: relative;
    }

        .privacy-option input[type="radio"] {
            display: none;
        }

        .privacy-option label {
            display: flex;
            align-items: center;
            justify-content: center;
            padding: var(--spacing-4);
            border: 2px solid var(--slate-200);
            border-radius: 12px;
            background: #f8fafc;
            cursor: pointer;
            transition: all 0.3s ease;
            margin-bottom: 0;
        }

        .privacy-option input[type="radio"]:checked + label {
            background: var(--sky-light);
            border-color: var(--sky-blue);
            color: var(--white);
        }

        .privacy-option i {
            margin-right: var(--spacing-3);
            font-size: 1.2rem;
        }

    /* Buttons */
    .btn-create-journey {
        width: 100%;
        padding: var(--spacing-4) var(--spacing-8);
        font-size: 1rem;
        font-weight: 600;
        background: linear-gradient(135deg, var(--sky-blue), var(--sky-light));
        color: var(--white);
        border: none;
        border-radius: 12px;
        cursor: pointer;
        transition: all 0.3s ease;
        margin-bottom: var(--spacing-4);
    }

        .btn-create-journey:hover {
            transform: translateY(-2px);
            box-shadow: 0 12px 32px rgba(14, 165, 233, 0.4);
        }

        .btn-create-journey:active {
            transform: translateY(0);
        }

    .btn-cancel {
        width: 100%;
        padding: var(--spacing-4) var(--spacing-8);
        font-size: 1rem;
        font-weight: 600;
        background: transparent;
        color: var(--slate);
        border: 2px solid var(--slate-200);
        border-radius: 12px;
        cursor: pointer;
        transition: all 0.3s ease;
    }

        .btn-cancel:hover {
            border-color: var(--sky-blue);
            color: var(--sky-blue);
        }

    /* ========== JOURNEY CONTROL TOOLBAR ========== */
    .journey-control-toolbar {
        position: relative;
        z-index: 10;
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border-bottom: 1px solid rgba(14, 165, 233, 0.1);
        box-shadow: 0 4px 24px rgba(30, 41, 59, 0.08);
        padding: var(--spacing-4) var(--spacing-6);
        margin-bottom: var(--spacing-6);
        border-radius: 0 0 16px 16px;
        transition: all 0.3s ease;
    }

    .toolbar-container {
        max-width: 1800px;
        margin: 0 auto;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: var(--spacing-4);
    }

    .toolbar-left,
    .toolbar-right {
        display: flex;
        align-items: center;
        gap: var(--spacing-3);
    }

    .toolbar-btn {
        display: flex;
        align-items: center;
        gap: var(--spacing-2);
        padding: var(--spacing-3) var(--spacing-6);
        background: var(--white);
        border: 1px solid var(--slate-200);
        border-radius: 10px;
        color: var(--deep-slate);
        font-weight: 600;
        font-size: 0.9rem;
        cursor: pointer;
        transition: all 0.3s ease;
        white-space: nowrap;
        position: relative;
    }

        .toolbar-btn:hover:not(:disabled) {
            border-color: var(--sky-blue);
            background: rgba(14, 165, 233, 0.05);
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(14, 165, 233, 0.15);
        }

        .toolbar-btn:active:not(:disabled) {
            transform: translateY(0);
        }

        .toolbar-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            background: #f8fafc;
        }

        .toolbar-btn.primary {
            background: linear-gradient(135deg, var(--sky-blue), var(--sky-light));
            color: var(--white);
            border-color: var(--sky-blue);
        }

            .toolbar-btn.primary:hover:not(:disabled) {
                box-shadow: 0 6px 20px rgba(14, 165, 233, 0.3);
            }

        .toolbar-btn.success {
            background: linear-gradient(135deg, #10b981, #34d399);
            color: var(--white);
            border-color: #10b981;
        }

            .toolbar-btn.success:hover:not(:disabled) {
                box-shadow: 0 6px 20px rgba(16, 185, 129, 0.3);
            }

        .toolbar-btn i {
            font-size: 1rem;
        }

        /* Tooltip */
        .toolbar-btn[data-tooltip]:disabled::after {
            content: attr(data-tooltip);
            position: absolute;
            bottom: calc(100% + 8px);
            left: 50%;
            transform: translateX(-50%);
            background: var(--deep-slate);
            color: var(--white);
            padding: var(--spacing-2) var(--spacing-4);
            border-radius: 6px;
            font-size: 0.8rem;
            white-space: nowrap;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.3s ease;
            z-index: 1000;
        }

        .toolbar-btn[data-tooltip]:disabled:hover::after {
            opacity: 1;
        }

        .toolbar-btn[data-tooltip]:disabled::before {
            content: '';
            position: absolute;
            bottom: calc(100% + 2px);
            left: 50%;
            transform: translateX(-50%);
            border: 6px solid transparent;
            border-top-color: var(--deep-slate);
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.3s ease;
        }

        .toolbar-btn[data-tooltip]:disabled:hover::before {
            opacity: 1;
        }

    /* Dropdown */
    .toolbar-dropdown {
        position: relative;
    }

    .dropdown-menu {
        position: absolute;
        top: calc(100% + 8px);
        right: 0;
        background: rgba(30, 41, 59, 0.95);
        border: 1px solid var(--slate-200);
        border-radius: 12px;
        box-shadow: 0 8px 32px rgba(30, 41, 59, 0.15);
        min-width: 200px;
        opacity: 0;
        visibility: hidden;
        transform: translateY(-10px);
        transition: all 0.3s ease;
        z-index: 9999;
    }

        .dropdown-menu.active,
        .dropdown-menu.show {
            opacity: 1;
            visibility: visible;
            transform: translateY(0);
        }

    .dropdown-item {
        display: flex;
        align-items: center;
        gap: var(--spacing-3);
        padding: var(--spacing-3) var(--spacing-4);
        color: var(--slate-light);
        font-size: 0.9rem;
        cursor: pointer;
        transition: all 0.2s ease;
        border: none;
        background: transparent;
        width: 100%;
        text-align: left;
    }

        .dropdown-item:first-child {
            border-radius: 12px 12px 0 0;
        }

        .dropdown-item:last-child {
            border-radius: 0 0 12px 12px;
        }

        .dropdown-item:hover:not(:disabled) {
            background: rgba(14, 165, 233, 0.08);
            color: var(--sky-blue);
        }

        .dropdown-item:disabled {
            opacity: 0.4;
            cursor: not-allowed;
        }

        .dropdown-item i {
            font-size: 1.1rem;
            width: 20px;
        }

    /* Toast Notification */
    .toast-container {
        position: fixed;
        top: 80px;
        right: var(--spacing-6);
        z-index: 10000;
        display: flex;
        flex-direction: column;
        gap: var(--spacing-3);
    }

    .toast {
        background: var(--white);
        border-radius: 12px;
        padding: var(--spacing-4) var(--spacing-6);
        box-shadow: 0 8px 32px rgba(30, 41, 59, 0.2);
        display: flex;
        align-items: center;
        gap: var(--spacing-3);
        min-width: 300px;
        animation: slideInRight 0.3s ease-out;
        border-left: 4px solid var(--sky-blue);
    }

        .toast.success {
            border-left-color: #10b981;
        }

        .toast.error {
            border-left-color: #ef4444;
        }

        .toast.warning {
            border-left-color: var(--amber);
        }

    .toast-icon {
        font-size: 1.5rem;
    }

    .toast.success .toast-icon {
        color: #10b981;
    }

    .toast.error .toast-icon {
        color: #ef4444;
    }

    .toast.warning .toast-icon {
        color: var(--amber);
    }

    .toast-content {
        flex: 1;
    }

    .toast-title {
        font-weight: 700;
        color: var(--deep-slate);
        margin-bottom: 2px;
        font-size: 0.95rem;
    }

    .toast-message {
        color: var(--slate);
        font-size: 0.85rem;
    }

    .toast-close {
        background: transparent;
        border: none;
        color: var(--slate);
        cursor: pointer;
        font-size: 1.3rem;
        padding: 0;
        width: 24px;
        height: 24px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        transition: all 0.2s ease;
    }

        .toast-close:hover {
            background: var(--slate-200);
            color: var(--deep-slate);
        }

    @@keyframes slideInRight {
        from {
            opacity: 0;
            transform: translateX(100%);
        }

        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    /* Preview Mode */
    .preview-mode {
        background: var(--white);
        border-radius: 16px;
        padding: var(--spacing-8);
        box-shadow: 0 4px 24px rgba(30, 41, 59, 0.08);
        animation: fadeIn 0.4s ease-out;
    }

    .preview-header {
        text-align: center;
        margin-bottom: var(--spacing-8);
        padding-bottom: var(--spacing-6);
        border-bottom: 2px solid var(--slate-200);
    }

    .preview-title {
        font-size: 2rem;
        font-weight: 800;
        color: var(--deep-slate);
        margin-bottom: var(--spacing-3);
    }

    .preview-subtitle {
        font-size: 1.1rem;
        color: var(--slate);
        font-weight: 500;
    }

    .preview-day {
        margin-bottom: var(--spacing-8);
    }

    .preview-day-header {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--deep-slate);
        margin-bottom: var(--spacing-4);
        padding-left: var(--spacing-4);
        border-left: 4px solid var(--sky-blue);
    }

    .preview-locations {
        display: flex;
        flex-direction: column;
        gap: var(--spacing-4);
        margin-left: var(--spacing-6);
    }

    /* Saved State Indicator */
    .save-indicator {
        display: flex;
        align-items: center;
        gap: var(--spacing-2);
        color: var(--slate);
        font-size: 0.85rem;
        font-weight: 500;
    }

        .save-indicator.saved {
            color: #10b981;
        }

        .save-indicator i {
            font-size: 0.9rem;
        }

    /* ========== JOURNEY EDITOR SCREEN ========== */
    .journey-editor-container {
        display: none;
        min-height: 100vh;
        background: #f8fafc;
    }

    .journey-editor-header {
        background: var(--white);
        border-bottom: 1px solid var(--slate-200);
        padding: var(--spacing-6);
        box-shadow: 0 2px 12px rgba(30, 41, 59, 0.06);
        position: relative;
        z-index: 5;
    }

        .journey-editor-header h2 {
            font-size: 1.8rem;
            font-weight: 700;
            color: var(--deep-slate);
            margin: 0 0 var(--spacing-3) 0;
        }

    .journey-info {
        font-size: 0.95rem;
        color: var(--slate);
        margin: 0;
    }

    .editor-content {
        display: grid;
        grid-template-columns: 1fr;
        gap: 0;
        padding: 0;
        width: 100%;
        margin: 0;
        min-height: calc(100vh - 200px);
    }

    /* Left Timeline */
    .timeline-section {
        display: flex;
        flex-direction: column;
        gap: var(--spacing-6);
        padding: var(--spacing-8);
        background: #f8fafc;
        border-right: 1px solid var(--slate-200);
        overflow-y: auto;
    }

    .timeline-header {
        font-size: 1.2rem;
        font-weight: 700;
        color: var(--deep-slate);
        margin-bottom: var(--spacing-4);
    }

    .day-card {
        background: var(--white);
        border-radius: 16px;
        padding: var(--spacing-6);
        box-shadow: 0 4px 16px rgba(30, 41, 59, 0.08);
        border-left: 4px solid var(--sky-blue);
        animation: fadeIn 0.4s ease-out;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .day-card.mood-chill {
        border-left-color: #10b981;
        background: linear-gradient(135deg, var(--white), rgba(16, 185, 129, 0.03));
        margin-bottom: var(--spacing-6);
    }

    .day-card.mood-adventure {
        border-left-color: #f59e0b;
        background: linear-gradient(135deg, var(--white), rgba(245, 158, 11, 0.03));
    }

    .day-card.mood-foodie {
        border-left-color: #ef4444;
        background: linear-gradient(135deg, var(--white), rgba(239, 68, 68, 0.03));
    }

    .day-card.mood-healing {
        border-left-color: #a855f7;
        background: linear-gradient(135deg, var(--white), rgba(168, 85, 247, 0.03));
    }

    .day-card.mood-culture {
        border-left-color: #06b6d4;
        background: linear-gradient(135deg, var(--white), rgba(6, 182, 212, 0.03));
    }

    .day-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: var(--spacing-4);
        padding-bottom: var(--spacing-4);
        border-bottom: 1px solid var(--slate-200);
    }

    .day-title {
        font-size: 1.3rem;
        font-weight: 700;
        color: var(--deep-slate);
    }

    .day-actions {
        display: flex;
        gap: var(--spacing-3);
    }

        .day-actions button {
            background: transparent;
            border: none;
            color: var(--slate);
            cursor: pointer;
            font-size: 1.2rem;
            transition: all 0.3s ease;
        }

            .day-actions button:hover {
                color: var(--sky-blue);
                transform: scale(1.15);
            }

    .day-content {
        display: flex;
        flex-direction: column;
        gap: var(--spacing-4);
    }

    /* Location Mini Card */
    .location-item {
        background: linear-gradient(135deg, rgba(248, 250, 252, 0.6), var(--white));
        border-radius: 12px;
        padding: var(--spacing-4);
        border: 1px solid rgba(14, 165, 233, 0.1);
        display: flex;
        gap: var(--spacing-3);
        transition: all 0.3s ease;
    }

        .location-item:hover {
            box-shadow: 0 4px 12px rgba(14, 165, 233, 0.15);
            transform: translateX(4px);
        }

    .location-thumb {
        width: 80px;
        height: 80px;
        border-radius: 10px;
        overflow: hidden;
        flex-shrink: 0;
    }

        .location-thumb img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .location-details {
        flex: 1;
    }

    .location-name {
        font-size: 0.95rem;
        font-weight: 700;
        color: var(--deep-slate);
        margin-bottom: var(--spacing-2);
    }

    .location-rating {
        font-size: 0.85rem;
        color: var(--amber);
        margin-bottom: var(--spacing-2);
    }

    .location-tags {
        display: flex;
        gap: var(--spacing-2);
        flex-wrap: wrap;
    }

    .location-tag {
        font-size: 0.75rem;
        background: rgba(14, 165, 233, 0.1);
        color: var(--sky-blue);
        padding: 2px 8px;
        border-radius: 6px;
        font-weight: 600;
    }

    /* Note Item */
    .note-item {
        background: linear-gradient(135deg, #fef3c7, rgba(254, 243, 199, 0.7));
        border-radius: 10px;
        padding: var(--spacing-4);
        border-left: 3px solid var(--amber);
        font-size: 0.95rem;
        color: var(--deep-slate);
        font-style: italic;
        position: relative;
    }

        .note-item::before {
            content: '✎';
            position: absolute;
            top: var(--spacing-2);
            right: var(--spacing-4);
            font-size: 1.2rem;
            color: rgba(245, 158, 11, 0.3);
        }

    /* Add Button */
    .add-item-btn {
        background: rgba(14, 165, 233, 0.1);
        border: 2px dashed var(--sky-light);
        border-radius: 12px;
        padding: var(--spacing-4);
        color: var(--sky-blue);
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        text-align: center;
        margin-top: var(--spacing-4);
    }

        .add-item-btn:hover {
            background: rgba(14, 165, 233, 0.15);
            border-color: var(--sky-blue);
        }

    /* Right Discovery Section */
    .discovery-section {
        display: flex;
        flex-direction: column;
        gap: var(--spacing-6);
        padding: var(--spacing-8);
        overflow-y: auto;
    }

    .discovery-header {
        font-size: 1.2rem;
        font-weight: 700;
        color: var(--deep-slate);
    }

    /* Location Cards Grid */
    .location-cards-container {
        display: grid;
        grid-template-columns: 1fr;
        gap: var(--spacing-8);
    }

    .location-card {
        background: var(--white);
        border-radius: 14px;
        overflow: hidden;
        box-shadow: 0 4px 16px rgba(30, 41, 59, 0.08);
        transition: all 0.3s ease;
        cursor: pointer;
        border: 1px solid rgba(14, 165, 233, 0.05);
    }

        .location-card:hover {
            box-shadow: 0 8px 24px rgba(14, 165, 233, 0.15);
            transform: translateY(-4px);
        }

    .location-card-image {
        width: 100%;
        height: 280px;
        overflow: hidden;
        position: relative;
    }

        .location-card-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
