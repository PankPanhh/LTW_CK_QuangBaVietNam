<script>
    // Sample location data
    const sampleLocations = [
        {
            id: 1,
            name: 'Phú Quốc - Thiên đường biển đảo',
            image: 'https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=500&h=300&fit=crop',
            rating: 4.8,
            description: 'Đảo ngọc với bãi biển trắng và nước biển trong xanh',
            tags: ['Hot', 'Biển', 'Nổi bật']
        },
        {
            id: 2,
            name: 'Hội An - Phố cổ tìm lại quá khứ',
            image: 'https://images.unsplash.com/photo-1583422409516-2895a77efded?w=500&h=300&fit=crop',
            rating: 4.9,
            description: 'Phố cổ với kiến trúc Á Đông độc đáo, là di sản thế giới UNESCO',
            tags: ['Văn hoá', 'Du lịch']
        },
        {
            id: 3,
            name: 'Đà Lạt - Thành phố ngàn hoa',
            image: 'https://images.unsplash.com/photo-1559827260-dc66d52bef19?w=500&h=300&fit=crop',
            rating: 4.7,
            description: 'Thành phố du lịch nổi tiếng với khí hậu mát mẻ quanh năm',
            tags: ['Nổi bật', 'Chữa lành']
        },
        {
            id: 4,
            name: 'Sapa - Núi rừng huyền bí',
            image: 'https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=500&h=300&fit=crop',
            rating: 4.6,
            description: 'Vùng cao nguyên với ruộng bậc thang và văn hoá dân tộc độc đáo',
            tags: ['Mới', 'Trekking']
        },
        {
            id: 5,
            name: 'Hạ Long - Vịnh kỳ vĩ thế giới',
            image: 'https://images.unsplash.com/photo-1505142468610-359e7d316be0?w=500&h=300&fit=crop',
            rating: 4.8,
            description: 'Di sản thế giới UNESCO với những hòn đảo xanh ngợp sóng',
            tags: ['Du lịch', 'Nổi bật']
        }
    ];

    const suggestionNames = [
        'Weekend in Hội An',
        'Đà Lạt healing trip',
        'Phú Quốc summer escape',
        'Sapa adventure 2024',
        'Hạ Long bay discovery'
    ];

    // Global state
    let pendingLocation = null;
    let selectedDayForLocation = null;
    let currentDayForNote = null;
    let isPreviewMode = false;
    let isSaved = false;
    let lastScrollPosition = 0;

    // Initialize
    function initJourney() {
        renderLocationCards();
    }

    // Render Location Cards
    function renderLocationCards() {
        const container = document.getElementById('locationsContainer');
        if (!container) return;
        container.innerHTML = sampleLocations.map(location => `
            <div class="location-card" data-location-id="${location.id}">
                <div class="location-card-image">
                    <img src="${location.image}" alt="${location.name}" />
                </div>
                <div class="location-card-content">
                    <div class="location-card-title">${location.name}</div>
                    <div class="location-card-rating">
                        <i class="bi bi-star-fill"></i> ${location.rating} / 5.0
                    </div>
                    <div class="location-card-desc">${location.description}</div>
                    <div class="location-card-footer">
                        <div class="location-card-tags">
                            ${location.tags.map(tag => `<span class="location-card-tag">${tag}</span>`).join('')}
                        </div>
                        <button type="button" class="btn-add-to-itinerary" onclick="addToItinerary(${location.id})">
                            <i class="bi bi-plus-lg"></i> Thêm
                        </button>
                    </div>
                </div>
            </div>
        `).join('');
    }

    // Update Suggestions
    function updateSuggestions() {
        const journeyNameEl = document.getElementById('journeyName');
        if (!(journeyNameEl instanceof HTMLInputElement)) return;
        const input = journeyNameEl.value.trim();
        const box = document.getElementById('suggestionsBox');
        if (!box) return;

        if (input.length > 0) {
            box.style.display = 'block';
            const chips = document.getElementById('suggestionChips');
            if (chips) chips.innerHTML = suggestionNames.map(name => `
                <div class="suggestion-chip" onclick="setSuggestion('${name}')">
                    ${name}
                </div>
            `).join('');
        } else {
            box.style.display = 'none';
        }
    }

    // Set Suggestion
    function setSuggestion(name) {
        const el = document.getElementById('journeyName');
        if (el instanceof HTMLInputElement) {
            el.value = name;
        }
    }

    // Start Journey Editor
    function startJourneyEditor(e) {
        e.preventDefault();

        const journeyNameEl = document.getElementById('journeyName');
        const startDateEl = document.getElementById('startDate');
        const endDateEl = document.getElementById('endDate');
        const privacyEl = document.querySelector('input[name="privacy"]:checked');

        if (!(journeyNameEl instanceof HTMLInputElement)) return;
        if (!(startDateEl instanceof HTMLInputElement)) return;
        if (!(endDateEl instanceof HTMLInputElement)) return;
        if (!(privacyEl instanceof HTMLInputElement)) return;

        const journeyName = journeyNameEl.value;
        const startDate = startDateEl.value;
        const endDate = endDateEl.value;
        const privacy = privacyEl.value;

        // Format dates
        const start = new Date(startDate);
        const end = new Date(endDate);
        const dateRange = start.toLocaleDateString('vi-VN') + ' - ' + end.toLocaleDateString('vi-VN');

        // Calculate days
        const days = Math.ceil((end.getTime() - start.getTime()) / (1000 * 60 * 60 * 24)) + 1;

        // Update editor header
        const editorTitle = document.getElementById('editorTitle');
        const journeyInfo = document.getElementById('journeyInfo');
        if (editorTitle && journeyInfo) {
            editorTitle.textContent = journeyName;
            journeyInfo.textContent = `${dateRange} | ${privacy === 'private' ? 'Riêng tư' : 'Công khai'}`;
        }

        // Generate day cards
        generateDayCards(days);

        // Switch screens
        const initScreen = document.getElementById('initScreen');
        const editorScreen = document.getElementById('editorScreen');
        if (initScreen && editorScreen) {
            initScreen.style.display = 'none';
            editorScreen.style.display = 'block';
        }

        // Store journey data
        window_journeyData = {
            name: journeyName,
            startDate: startDate,
            endDate: endDate,
            privacy: privacy,
            days: days,
            locations: [],
            dayData: {}
        };

        // Initialize day data
        for (let i = 1; i <= days; i++) {
            window_journeyData.dayData[i] = {
                locations: [],
                notes: []
            };
        }
    }

    // Generate Day Cards
    function generateDayCards(count) {
        const container = document.getElementById('daysContainer');
        if (!container) return;
        let html = '';

        for (let i = 1; i <= count; i++) {
            html += `
                <div class="day-card mood-chill" id="day-${i}">
                    <div class="day-header">
                        <div>
                            <div class="day-title">Day ${i}</div>
                        </div>
                        <div class="day-actions">
                            <button type="button" title="Thêm ghi chú" onclick="openNoteModal(${i})">
                                <i class="bi bi-plus-circle"></i>
                            </button>
                            <button type="button" title="Xóa ngày" onclick="removeDay(${i})">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    </div>
                    <div class="day-content" id="day-content-${i}">
                        <div class="empty-day-state">
                            <i class="bi bi-calendar-plus"></i>
                            Chưa có địa điểm nào. Thêm từ danh sách bên phải!
                        </div>
                    </div>
                </div>
            `;
        }

        container.innerHTML = html;
    }

    // ========== ADD LOCATION FLOW ==========

    // Step 1: Open Day Selection Modal
    function addToItinerary(locationId) {
        const location = sampleLocations.find(l => l.id === locationId);
        if (!location) return;

        pendingLocation = location;
        selectedDayForLocation = null;

        // Update modal title
        const locationNameEl = document.getElementById('selectedLocationName');
        if (locationNameEl) locationNameEl.textContent = location.name;

        // Generate day options
        const grid = document.getElementById('daySelectionGrid');
        if (!grid) return;
        let html = '';
        for (let i = 1; i <= (window_journeyData?.days || 0); i++) {
            html += `
                <div class="day-option" onclick="selectDay(${i})">
                    <i class="bi bi-calendar3"></i><br>
                    Day ${i}
                </div>
            `;
        }
        grid.innerHTML = html;

        // Show modal
        document.getElementById('daySelectionModal').classList.add('active');

        // Trigger flying animation
        const card = document.querySelector(`[data-location-id="${locationId}"]`);
        if (card) {
            card.classList.add('flying');
            setTimeout(() => card.classList.remove('flying'), 600);
        }
    }

    // Step 2: Select Day
    function selectDay(dayNum) {
        selectedDayForLocation = dayNum;

        // Update UI
        document.querySelectorAll('.day-option').forEach(opt => opt.classList.remove('selected'));
        const target = event?.target;
        if (target instanceof Element) {
            const dayOpt = target.closest('.day-option');
            if (dayOpt instanceof Element) dayOpt.classList.add('selected');
        }
    }

    // Step 3: Confirm Add Location
    function confirmAddLocation() {
        if (!selectedDayForLocation || !pendingLocation) {
            alert('Vui lòng chọn ngày');
            return;
        }

        addLocationToDay(selectedDayForLocation, pendingLocation);
        closeDayModal();
    }

    // Close Day Modal
    function closeDayModal() {
        document.getElementById('daySelectionModal').classList.remove('active');
        pendingLocation = null;
        selectedDayForLocation = null;
    }

    // Add Location to Day
    function addLocationToDay(dayNum, location) {
        const dayContent = document.getElementById(`day-content-${dayNum}`);
        if (!dayContent) return;

        // Remove empty state
        const emptyState = dayContent.querySelector('.empty-day-state');
        if (emptyState) {
            emptyState.remove();
        }

        const locationId = `location-${dayNum}-${Date.now()}`;
        const locationHtml = `
            <div class="location-item" id="${locationId}">
                <button type="button" class="location-item-remove" onclick="removeLocation('${locationId}', ${dayNum})">
                    <i class="bi bi-x"></i>
                </button>
                <div class="location-thumb">
                    <img src="${location.image}" alt="${location.name}" />
                </div>
                <div class="location-details">
                    <div class="location-name">${location.name}</div>
                    <div class="location-rating">
                        <i class="bi bi-star-fill"></i> ${location.rating} / 5.0
                    </div>
                    <div class="location-tags">
                        ${location.tags.map(tag => `<span class="location-tag">${tag}</span>`).join('')}
                    </div>
                </div>
            </div>
        `;

        dayContent.insertAdjacentHTML('beforeend', locationHtml);

        // Track location
        if (window_journeyData) {
            if (!window_journeyData.locations.includes(location.id)) {
                window_journeyData.locations.push(location.id);
            }
            window_journeyData.dayData[dayNum].locations.push(location);
        }

        // Show smart suggestions
        showSmartSuggestions();

        // Mark as unsaved
        markUnsaved();

        // Update preview button state
        updatePreviewButton();
    }

    // Remove Location
    function removeLocation(locationId, dayNum) {
        if (confirm('Xóa địa điểm này khỏi lịch trình?')) {
            const element = document.getElementById(locationId);
            element.style.animation = 'fadeOut 0.3s ease-out';
            setTimeout(() => {
                element.remove();
                checkEmptyDay(dayNum);
            }, 300);
        }
    }

    // ========== ADD NOTE FLOW ==========

    // Open Note Modal
    function openNoteModal(dayNum) {
        currentDayForNote = dayNum;
        const textarea = document.getElementById('noteTextarea');
        if (textarea instanceof HTMLTextAreaElement) {
            textarea.value = '';
        }
        const modal = document.getElementById('addNoteModal');
        if (modal) modal.classList.add('active');
    }

    // Close Note Modal
    function closeNoteModal() {
        document.getElementById('addNoteModal').classList.remove('active');
        currentDayForNote = null;
    }

    // Confirm Add Note
    function confirmAddNote() {
        const textarea = document.getElementById('noteTextarea');
        if (!(textarea instanceof HTMLTextAreaElement)) return;
        const noteText = textarea.value.trim();
        if (!noteText) {
            alert('Vui lòng nhập nội dung ghi chú');
            return;
        }

        if (!currentDayForNote) return;

        addNoteToDay(currentDayForNote, noteText);
        closeNoteModal();
    }

    // Add Note to Day
    function addNoteToDay(dayNum, noteText) {
        const dayContent = document.getElementById(`day-content-${dayNum}`);

        // Remove empty state
        const emptyState = dayContent.querySelector('.empty-day-state');
        if (emptyState) {
            emptyState.remove();
        }

        const noteId = `note-${dayNum}-${Date.now()}`;
        const noteHtml = `
            <div class="note-item" id="${noteId}">
                <button type="button" class="note-item-remove" onclick="removeNote('${noteId}', ${dayNum})">
                    <i class="bi bi-x"></i>
                </button>
                ${noteText}
            </div>
        `;

        dayContent.insertAdjacentHTML('beforeend', noteHtml);

        // Track note
        if (window_journeyData) {
            window_journeyData.dayData[dayNum].notes.push(noteText);
        }

        // Mark as unsaved
        markUnsaved();
    }

    // Remove Note
    function removeNote(noteId, dayNum) {
        if (confirm('Xóa ghi chú này?')) {
            const element = document.getElementById(noteId);
            element.style.animation = 'fadeOut 0.3s ease-out';
            setTimeout(() => {
                element.remove();
                checkEmptyDay(dayNum);
            }, 300);
        }
    }

    // ========== OTHER FUNCTIONS ==========

    // Remove Day
    function removeDay(dayNum) {
        if (confirm(`Xóa Day ${dayNum} khỏi lịch trình?`)) {
            const dayCard = document.getElementById(`day-${dayNum}`);
            dayCard.style.animation = 'fadeOut 0.3s ease-out';
            setTimeout(() => dayCard.remove(), 300);
        }
    }

    // Check if day is empty and show empty state
    function checkEmptyDay(dayNum) {
        const dayContent = document.getElementById(`day-content-${dayNum}`);
        const items = dayContent.querySelectorAll('.location-item, .note-item');

        if (items.length === 0) {
            dayContent.innerHTML = `
                <div class="empty-day-state">
                    <i class="bi bi-calendar-plus"></i>
                    Chưa có địa điểm nào. Thêm từ danh sách bên phải!
                </div>
            `;
        }
    }

    // Select Mood
    function selectMood(mood) {
        document.querySelectorAll('.mood-btn').forEach(btn => btn.classList.remove('active'));
        event.target.closest('.mood-btn').classList.add('active');

        // Update day card mood
        const moodClass = `mood-${mood}`;
        document.querySelectorAll('.day-card').forEach(card => {
            card.classList.remove('mood-chill', 'mood-adventure', 'mood-foodie', 'mood-healing', 'mood-culture');
            card.classList.add(moodClass);
        });
    }

    // Show Smart Suggestions
    function showSmartSuggestions() {
        const box = document.getElementById('smartSuggestionsBox');
        const container = document.getElementById('suggestionsContainer');

        // Simple smart suggestions
        const suggestions = [
            'Nếu bạn thích Hội An, hãy thêm Biển An Bàng',
            'Các du khách thường thêm Làng rau Trà Quế khi đã chọn Hội An',
            'Điểm ăn uống nổi tiếng gần đây: Tú Tiên Restaurant',
            'Thời tiết tốt nhất vào buổi sáng - hãy lên kế hoạch sôi động'
        ];

        if (window_journeyData && window_journeyData.locations.length > 0) {
            container.innerHTML = suggestions.map(text => `
                <div class="suggestion-item">
                    <i class="bi bi-check-circle"></i> ${text}
                </div>
            `).join('');
            box.style.display = 'block';
        }
    }

    // Add fadeOut animation
    const style = document.createElement('style');
    style.textContent = `
        @@keyframes fadeOut {
            from {
                opacity: 1;
                transform: scale(1);
            }
            to {
                opacity: 0;
                transform: scale(0.8);
            }
        }
    `;
    document.head.appendChild(style);

    // ========== TOOLBAR FUNCTIONS ==========

    // Add New Day
    function addNewDay() {
        if (!window_journeyData) return;

        const newDayNum = window_journeyData.days + 1;
        window_journeyData.days = newDayNum;
        window_journeyData.dayData[newDayNum] = {
            locations: [],
            notes: []
        };

        const container = document.getElementById('daysContainer');
        if (!container) return;
        const dayHtml = `
            <div class="day-card mood-chill" id="day-${newDayNum}" style="animation: slideInUp 0.4s ease-out;">
                <div class="day-header">
                    <div>
                        <div class="day-title">Day ${newDayNum}</div>
                    </div>
                    <div class="day-actions">
                        <button type="button" title="Thêm ghi chú" onclick="openNoteModal(${newDayNum})">
                            <i class="bi bi-plus-circle"></i>
                        </button>
                        <button type="button" title="Xóa ngày" onclick="removeDay(${newDayNum})">
                            <i class="bi bi-trash"></i>
                        </button>
                    </div>
                </div>
                <div class="day-content" id="day-content-${newDayNum}">
                    <div class="empty-day-state">
                        <i class="bi bi-calendar-plus"></i>
                        Chưa có địa điểm nào. Thêm từ danh sách bên phải!
                    </div>
                </div>
            </div>
        `;

        container.insertAdjacentHTML('beforeend', dayHtml);

        // Scroll to new day
        setTimeout(() => {
            const newDayElement = document.getElementById(`day-${newDayNum}`);
            if (newDayElement) {
                newDayElement.scrollIntoView({ behavior: 'smooth', block: 'center' });
            }
        }, 100);

        // Mark as unsaved
        markUnsaved();

        showToast('success', 'Đã thêm ngày mới', `Day ${newDayNum} đã được thêm vào lịch trình`);
    }

    // Save Journey
    function saveJourney() {
        if (!window_journeyData) return;

        // Simulate save (in real app, would send to server)
        const saveBtn = document.getElementById('btnSaveJourney');
        if (!(saveBtn instanceof HTMLButtonElement)) return;
        saveBtn.disabled = true;
        saveBtn.innerHTML = '<i class="bi bi-hourglass-split"></i><span>Đang lưu...</span>';

        setTimeout(() => {
            isSaved = true;
            saveBtn.disabled = false;
            saveBtn.innerHTML = '<i class="bi bi-check-circle"></i><span>Lưu lịch trình</span>';

            // Update save indicator
            const indicator = document.getElementById('saveIndicator');
            if (indicator) {
                indicator.classList.add('saved');
                indicator.innerHTML = '<i class="bi bi-check-circle-fill"></i><span>Đã lưu</span>';
            }

            showToast('success', 'Lưu thành công', 'Lịch trình của bạn đã được lưu');

            console.log('Saved journey data:', window_journeyData);
        }, 1000);
    }

    // Mark as Unsaved
    function markUnsaved() {
        isSaved = false;
        const indicator = document.getElementById('saveIndicator');
        if (indicator) {
            indicator.classList.remove('saved');
            indicator.innerHTML = '<i class="bi bi-clock-history"></i><span>Chưa lưu</span>';
        }
    }

    // Toggle Preview
    function togglePreview() {
        if (!window_journeyData) return;

        // Save scroll position
        lastScrollPosition = window.scrollY;

        isPreviewMode = true;

        // Generate preview content
        generatePreview();

        // Toggle visibility with fade
        const editorMode = document.getElementById('editorMode');
        const previewMode = document.getElementById('previewMode');
        const btnPreview = document.getElementById('btnPreview');
        const btnBackToEdit = document.getElementById('btnBackToEdit');

        if (!editorMode || !previewMode || !btnPreview || !btnBackToEdit) return;

        editorMode.style.animation = 'fadeOut 0.3s ease-out';
        setTimeout(() => {
            editorMode.style.display = 'none';
            previewMode.style.display = 'block';
            previewMode.style.animation = 'fadeIn 0.4s ease-out';

            btnPreview.style.display = 'none';
            btnBackToEdit.style.display = 'flex';

            // Scroll to top
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }, 300);
    }

    // Back to Edit
    function backToEdit() {
        isPreviewMode = false;

        const editorMode = document.getElementById('editorMode');
        const previewMode = document.getElementById('previewMode');
        const btnPreview = document.getElementById('btnPreview');
        const btnBackToEdit = document.getElementById('btnBackToEdit');

        if (!editorMode || !previewMode || !btnPreview || !btnBackToEdit) return;

        previewMode.style.animation = 'fadeOut 0.3s ease-out';
        setTimeout(() => {
            previewMode.style.display = 'none';
            editorMode.style.display = 'block';
            editorMode.style.animation = 'fadeIn 0.4s ease-out';

            btnPreview.style.display = 'flex';
            btnBackToEdit.style.display = 'none';

            // Restore scroll position
            setTimeout(() => {
                window.scrollTo({ top: lastScrollPosition, behavior: 'smooth' });
            }, 100);
        }, 300);
    }

    // Generate Preview
    function generatePreview() {
        const previewContainer = document.getElementById('previewMode');
        if (!previewContainer || !window_journeyData) return;
        let html = `
            <div class="preview-header">
                <div class="preview-title">${window_journeyData.name}</div>
                <div class="preview-subtitle">
                    ${new Date(window_journeyData.startDate).toLocaleDateString('vi-VN')} -
                    ${new Date(window_journeyData.endDate).toLocaleDateString('vi-VN')} |
                    ${window_journeyData.privacy === 'private' ? 'Riêng tư' : 'Công khai'}
                </div>
            </div>
        `;

        for (let i = 1; i <= window_journeyData.days; i++) {
            const dayData = window_journeyData.dayData[i];
            if (!dayData) continue;

            html += `<div class="preview-day">`;
            html += `<div class="preview-day-header">Day ${i}</div>`;

            if (dayData.locations && dayData.locations.length > 0) {
                html += `<div class="preview-locations">`;
                dayData.locations.forEach(location => {
                    html += `
                        <div class="location-item">
                            <div class="location-thumb">
                                <img src="${location.image}" alt="${location.name}" />
                            </div>
                            <div class="location-details">
                                <div class="location-name">${location.name}</div>
                                <div class="location-rating">
                                    <i class="bi bi-star-fill"></i> ${location.rating} / 5.0
                                </div>
                                <div class="location-tags">
                                    ${location.tags.map(tag => `<span class="location-tag">${tag}</span>`).join('')}
                                </div>
                            </div>
                        </div>
                    `;
                });
                html += `</div>`;
            }

            if (dayData.notes && dayData.notes.length > 0) {
                dayData.notes.forEach(note => {
                    html += `<div class="note-item" style="margin-left: var(--spacing-6); margin-top: var(--spacing-4);">${note}</div>`;
                });
            }

            if ((!dayData.locations || dayData.locations.length === 0) && (!dayData.notes || dayData.notes.length === 0)) {
                html += `<div style="margin-left: var(--spacing-6); color: var(--slate); font-style: italic;">Chưa có kế hoạch cho ngày này</div>`;
            }

            html += `</div>`;
        }

        previewContainer.innerHTML = html;
    }

    // Toggle Share Dropdown
    function toggleShareDropdown() {
        const dropdown = document.getElementById('shareDropdown');
        dropdown.classList.toggle('active');
        dropdown.classList.toggle('show');
    }

    // Share Journey
    function shareJourney(platform) {
        if (!window_journeyData) return;

        const journeyUrl = window.location.href + '?id=' + Date.now();

        if (platform === 'link') {
            navigator.clipboard.writeText(journeyUrl).then(() => {
                showToast('success', 'Đã sao chép', 'Link hành trình đã được sao chép vào clipboard');
            }).catch(() => {
                showToast('error', 'Lỗi', 'Không thể sao chép link');
            });
        } else if (platform === 'facebook') {
            const fbUrl = `https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(journeyUrl)}`;
            window.open(fbUrl, '_blank', 'width=600,height=400');
        }

        toggleShareDropdown();
    }

    // Export Journey
    function exportJourney(format) {
        if (!window_journeyData) return;

        if (format === 'pdf') {
            showToast('warning', 'Chức năng đang phát triển', 'Tính năng xuất PDF sẽ sớm được cập nhật');
        } else if (format === 'image') {
            showToast('warning', 'Chức năng đang phát triển', 'Tính năng lưu ảnh sẽ sớm được cập nhật');
        }

        toggleShareDropdown();
    }

    // Show Toast
    function showToast(type, title, message) {
        const container = document.getElementById('toastContainer');
        const toastId = 'toast-' + Date.now();

        const icons = {
            success: 'bi-check-circle-fill',
            error: 'bi-x-circle-fill',
            warning: 'bi-exclamation-triangle-fill',
            info: 'bi-info-circle-fill'
        };

        const toast = document.createElement('div');
        toast.className = `toast ${type}`;
        toast.id = toastId;
        toast.innerHTML = `
            <i class="bi ${icons[type]} toast-icon"></i>
            <div class="toast-content">
                <div class="toast-title">${title}</div>
                <div class="toast-message">${message}</div>
            </div>
            <button type="button" class="toast-close" onclick="closeToast('${toastId}')">
                <i class="bi bi-x"></i>
            </button>
        `;

        container.appendChild(toast);

        // Auto remove after 5 seconds
        setTimeout(() => {
            closeToast(toastId);
        }, 5000);
    }

    // Close Toast
    function closeToast(toastId) {
        const toast = document.getElementById(toastId);
        if (toast) {
            toast.style.animation = 'slideOutRight 0.3s ease-out';
            setTimeout(() => toast.remove(), 300);
        }
    }

    // Update Preview Button State
    function updatePreviewButton() {
        const btnPreview = document.getElementById('btnPreview');
        if (!window_journeyData) return;

        let hasLocations = false;
        for (let i = 1; i <= window_journeyData.days; i++) {
            const dayData = window_journeyData.dayData[i];
            if (dayData && dayData.locations && dayData.locations.length > 0) {
                hasLocations = true;
                break;
            }
        }

        if (hasLocations) {
            btnPreview.disabled = false;
            btnPreview.removeAttribute('data-tooltip');
        } else {
            btnPreview.disabled = true;
            btnPreview.setAttribute('data-tooltip', 'Thêm ít nhất 1 địa điểm để xem trước');
        }
    }

    // Close dropdown when clicking outside
    document.addEventListener('click', function(e) {
        const dropdown = document.getElementById('shareDropdown');
        if (dropdown && !e.target.closest('.toolbar-dropdown')) {
            dropdown.classList.remove('active');
        }
    });

    // Add slideOutRight animation
    const slideOutStyle = document.createElement('style');
    slideOutStyle.textContent = `
        @@keyframes slideOutRight {
            from {
                opacity: 1;
                transform: translateX(0);
            }
            to {
                opacity: 0;
                transform: translateX(100%);
            }
        }
    `;
    document.head.appendChild(slideOutStyle);

    // Initialize on page load
    window.addEventListener('load', initJourney);

    // Close modals on overlay click
    document.addEventListener('click', function(e) {
        if (e.target.classList.contains('modal-overlay')) {
            closeDayModal();
            closeNoteModal();
        }
    });
</script>