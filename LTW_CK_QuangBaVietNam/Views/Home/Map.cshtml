@{
    ViewBag.Title = "Bản đồ";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    :root {
        --deep-slate: #1e293b;
        --slate: #334155;
        --sky-blue: #0EA5E9;
        --sky-light: #38BDF8;
        --slate-light: #cbd5e1;
        --slate-200: #e2e8f0;
        --white: #ffffff;
        --spacing-2: 0.5rem;
        --spacing-3: 0.75rem;
        --spacing-4: 1rem;
        --spacing-6: 1.5rem;
        --spacing-8: 2rem;
        --spacing-12: 3rem;
        --spacing-16: 4rem;
    }

    /* Map Container - works within layout */
    .map-container {
        display: flex;
        gap: var(--spacing-6);
        padding: var(--spacing-6) 0;
        background: #f8fafc;
        min-height: 600px;
    }

    .map-wrapper {
        flex: 2;
        position: relative;
        background: white;
        border-radius: 24px;
        overflow: hidden;
        box-shadow: 0 8px 40px rgba(30, 41, 59, 0.12);
        height: 600px;
    }

    #map {
        width: 100%;
        height: 100%;
        z-index: 1;
    }

    /* Search & Filter Bar */
    .map-toolbar {
        position: absolute;
        top: var(--spacing-6);
        left: var(--spacing-6);
        right: var(--spacing-6);
        z-index: 100;
        display: flex;
        gap: var(--spacing-3);
        flex-wrap: wrap;
    }

    .map-search-box {
        flex: 1;
        min-width: 250px;
        background: rgba(255, 255, 255, 0.98);
        backdrop-filter: blur(20px);
        border-radius: 999px;
        padding: var(--spacing-3);
        display: flex;
        align-items: center;
        gap: var(--spacing-3);
        border: 2px solid rgba(14, 165, 233, 0.25);
        box-shadow: 0 4px 24px rgba(30, 41, 59, 0.1);
        transition: all 0.3s ease;
        margin-left: 50px;
    }

    .map-search-box:focus-within {
        border-color: var(--sky-blue);
        box-shadow: 0 8px 32px rgba(14, 165, 233, 0.2);
    }

    .map-search-box input {
        flex: 1;
        border: none;
        background: transparent;
        outline: none;
        font-size: 1rem;
        color: var(--deep-slate);
        padding: var(--spacing-3) var(--spacing-4);
    }

    .map-search-box input::placeholder {
        color: #94a3b8;
    }

    .map-search-box button {
        background: linear-gradient(135deg, var(--sky-blue), var(--sky-light));
        color: white;
        border: none;
        width: 44px;
        height: 44px;
        border-radius: 999px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s ease;
        flex-shrink: 0;
    }

    .map-search-box button:hover {
        transform: scale(1.08);
    }

    /* Filter Buttons */
    .filter-group {
        display: flex;
        gap: var(--spacing-2);
        background: rgba(255, 255, 255, 0.98);
        backdrop-filter: blur(20px);
        border-radius: 999px;
        padding: var(--spacing-3);
        box-shadow: 0 4px 24px rgba(30, 41, 59, 0.1);
        border: 2px solid rgba(14, 165, 233, 0.25);
        overflow-x: auto;
        margin-left: auto;
    }

    .filter-btn {
        padding: var(--spacing-3) var(--spacing-6);
        border: 2px solid transparent;
        background: white;
        border-radius: 999px;
        cursor: pointer;
        font-weight: 600;
        font-size: 0.875rem;
        color: var(--slate);
        transition: all 0.3s ease;
        white-space: nowrap;
        flex-shrink: 0;
    }

    .filter-btn:hover {
        background: rgba(14, 165, 233, 0.08);
        border-color: var(--sky-blue);
        color: var(--deep-slate);
    }

    .filter-btn.active {
        background: linear-gradient(135deg, var(--sky-blue), var(--sky-light));
        color: white;
        border-color: var(--sky-blue);
    }

    /* Info Panel */
    .info-panel {
        flex: 1;
        background: white;
        border-radius: 24px;
        overflow-y: auto;
        box-shadow: 0 8px 40px rgba(30, 41, 59, 0.12);
        display: flex;
        flex-direction: column;
    }

    .info-panel-empty {
        display: flex;
        align-items: center;
        justify-content: center;
        height: 100%;
        color: #94a3b8;
        text-align: center;
        padding: var(--spacing-6);
    }

    .info-panel-empty i {
        font-size: 3rem;
        margin-bottom: var(--spacing-4);
        opacity: 0.5;
    }

    .location-info {
        padding: var(--spacing-6);
        display: flex;
        flex-direction: column;
        gap: var(--spacing-6);
    }

    .location-image {
        width: 100%;
        height: 300px;
        object-fit: cover;
        border-radius: 20px;
        margin: -var(--spacing-6) -var(--spacing-6) 0 -var(--spacing-6);
    }

    .location-header {
        display: flex;
        justify-content: space-between;
        align-items: start;
        gap: var(--spacing-4);
    }

    .location-title {
        flex: 1;
    }

    .location-title h3 {
        font-size: 1.75rem;
        font-weight: 800;
        color: var(--deep-slate);
        margin: 0 0 var(--spacing-2) 0;
        line-height: 1.3;
    }

    .location-title p {
        color: #94a3b8;
        font-size: 0.9375rem;
        margin: 0;
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .favorite-btn {
        width: 44px;
        height: 44px;
        border: 2px solid var(--slate-200);
        background: white;
        border-radius: 50%;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.25rem;
        transition: all 0.3s ease;
        flex-shrink: 0;
    }

    .favorite-btn:hover {
        border-color: var(--sky-blue);
        color: var(--sky-blue);
    }

    .favorite-btn.active {
        background: rgba(14, 165, 233, 0.1);
        border-color: var(--sky-blue);
        color: var(--sky-blue);
    }

    .location-description {
        color: #64748b;
        line-height: 1.8;
        font-size: 0.9375rem;
    }

    .location-type-badge {
        display: inline-block;
        padding: var(--spacing-2) var(--spacing-4);
        background: rgba(14, 165, 233, 0.1);
        border-radius: 999px;
        font-size: 0.8125rem;
        color: var(--sky-blue);
        font-weight: 600;
        margin-bottom: var(--spacing-4);
    }

    .action-buttons {
        display: flex;
        gap: var(--spacing-3);
        margin-top: auto;
    }

    .btn-view-details {
        flex: 1;
        padding: var(--spacing-4) var(--spacing-6);
        background: linear-gradient(135deg, var(--sky-blue), var(--sky-light));
        color: white;
        border: none;
        border-radius: 12px;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.3s ease;
        text-decoration: none;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: var(--spacing-3);
    }

    .btn-view-details:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 24px rgba(14, 165, 233, 0.3);
        color: white;
        text-decoration: none;
    }

    .btn-add-itinerary {
        flex: 1;
        padding: var(--spacing-4) var(--spacing-6);
        background: white;
        color: var(--sky-blue);
        border: 2px solid var(--sky-blue);
        border-radius: 12px;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: var(--spacing-3);
    }

    .btn-add-itinerary:hover {
        background: rgba(14, 165, 233, 0.08);
        transform: translateY(-3px);
    }

    /* Leaflet Overrides */
    .leaflet-control-zoom {
        border-radius: 12px;
        box-shadow: 0 4px 12px rgba(30, 41, 59, 0.15) !important;
        border: 2px solid rgba(14, 165, 233, 0.2) !important;
    }

    .leaflet-control-zoom a {
        background-color: white !important;
        color: var(--deep-slate) !important;
        border: none !important;
        font-size: 1.2rem;
        width: 44px !important;
        height: 44px !important;
        line-height: 44px !important;
    }

    .leaflet-control-zoom a:hover {
        background-color: rgba(14, 165, 233, 0.1) !important;
        color: var(--sky-blue) !important;
    }

    .leaflet-popup-content-wrapper {
        background: rgba(255, 255, 255, 0.98) !important;
        backdrop-filter: blur(20px) !important;
        border-radius: 16px !important;
        border: 2px solid rgba(14, 165, 233, 0.25) !important;
        box-shadow: 0 8px 32px rgba(30, 41, 59, 0.15) !important;
    }

    .leaflet-popup-tip {
        background: rgba(255, 255, 255, 0.98) !important;
        border: 2px solid rgba(14, 165, 233, 0.25) !important;
    }

    .leaflet-popup-content {
        padding: var(--spacing-4) !important;
        font-size: 0.9375rem !important;
    }

    /* Map Controls Responsive */
    @@media (max-width: 1200px) {
        .map-container {
            flex-direction: column;
            gap: var(--spacing-4);
        }

        .map-wrapper {
            flex: 1;
            height: 500px;
        }

        .info-panel {
            flex: 1;
            height: 400px;
        }
    }

    @@media (max-width: 768px) {
        .map-toolbar {
            flex-direction: column;
        }

        .search-box {
            min-width: 100%;
        }

        .filter-group {
            min-width: 100%;
        }

        .map-wrapper {
            height: 450px;
        }

        .info-panel {
            height: 350px;
        }
    }
</style>

<!-- Map Section wrapped in Bootstrap Container -->
<div class="container-fluid">
    <section class="map-container">
        <!-- Map -->
        <div class="map-wrapper">
            

            <!-- Search & Filter Group -->
            <div class="map-toolbar" style="top: 20px;">
                <div class="map-search-box">
                    <i class="bi bi-search" style="color: #94a3b8; font-size: 1.1rem;"></i>
                    <input type="text" id="searchInput" placeholder="Tìm kiếm địa điểm...">
                    <button id="searchBtn" type="button" aria-label="Tìm kiếm">
                        <i class="bi bi-arrow-right"></i>
                    </button>
                </div>
                <div class="filter-group">
                    <button class="filter-btn active" data-filter="all">Tất cả</button>
                    <button class="filter-btn" data-filter="nature">Thiên Nhiên</button>
                    <button class="filter-btn" data-filter="culture">Văn Hóa</button>
                    <button class="filter-btn" data-filter="beach">Biển Đảo</button>
                    <button class="filter-btn" data-filter="cuisine">Ẩm Thực</button>
                </div>
            </div>

            <!-- Leaflet Map -->
            <div id="map"></div>
        </div>

        <!-- Info Panel -->
        <div class="info-panel">
            <div class="info-panel-empty">
                <div>
                    <i class="bi bi-map"></i>
                    <p>Nhấp vào một địa điểm để xem thông tin chi tiết</p>
                </div>
            </div>
        </div>
    </section>
</div>

<!-- Leaflet CSS & JS -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css" />
<script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>

<script>
    // Vietnam locations data
    const locations = [
        {
            id: 1,
            name: "Vịnh Hạ Long",
            region: "Quảng Ninh",
            coordinates: [20.8554, 107.1804],
            category: "nature",
            image: "https://images.unsplash.com/photo-1528127269322-539801943592?w=600",
            description: "Di sản thiên nhiên thế giới với hàng nghìn đảo đá vôi kỳ vĩ giữa làn nước xanh ngọc. Vịnh Hạ Long là một trong những kỳ quan thiên nhiên nổi tiếng nhất của Việt Nam.",
            badge: "Di sản thế giới"
        },
        {
            id: 2,
            name: "Phố cổ Hội An",
            region: "Quảng Nam",
            coordinates: [15.8801, 108.3261],
            category: "culture",
            image: "https://images.unsplash.com/photo-1559592413-7cec4d0cae2b?w=600",
            description: "Phố đèn lồng rực rỡ, nơi thời gian lắng đọng trong từng mái ngói cổ. Phố cổ Hội An là một địa điểm du lịch được yêu thích với kiến trúc độc đáo.",
            badge: "Văn hóa cổ"
        },
        {
            id: 3,
            name: "Đà Lạt",
            region: "Lâm Đồng",
            coordinates: [11.9388, 108.4453],
            category: "nature",
            image: "https://images.unsplash.com/photo-1578895101408-1a36b834405b?w=600",
            description: "Thành phố sương mù với khí hậu ôn hòa và những đồi thông lãng mạn. Đà Lạt là điểm đến lý tưởng cho những ai muốn thoát khỏi nắng nóng của thành phố.",
            badge: "Thành phố nghỉ dưỡng"
        },
        {
            id: 4,
            name: "Ruộng bậc thang Sa Pa",
            region: "Lào Cai",
            coordinates: [22.3372, 103.8426],
            category: "nature",
            image: "https://images.unsplash.com/photo-1583417319070-4a69db38a482?w=600",
            description: "Những bậc thang nông nghiệp tinh tế, tạo nên cảnh quan kỳ diệu trên núi cao. Sa Pa nổi tiếng với khí hậu mát mẻ và các bậc ruộng đẹp như tranh.",
            badge: "Thiên nhiên tươi mới"
        },
        {
            id: 5,
            name: "Đảo Phú Quốc",
            region: "Kiên Giang",
            coordinates: [10.1865, 103.9542],
            category: "beach",
            image: "https://images.unsplash.com/photo-1540611025311-01df3cef54b5?w=600",
            description: "Thiên đường biển nhiệt đới với bãi cát trắng và hoàng hôn rực rỡ trên mặt nước. Phú Quốc là hòn đảo lớn nhất Việt Nam với nhiều bãi biển đẹp.",
            badge: "Biển đảo"
        },
        {
            id: 6,
            name: "Thành phố Hồ Chí Minh",
            region: "TP HCM",
            coordinates: [10.7769, 106.6869],
            category: "culture",
            image: "https://images.unsplash.com/photo-1583417319070-4a69db38a482?w=600",
            description: "Nhịp sống không bao giờ ngủ, nơi hòa quyện giữa truyền thống và hiện đại. TPHCM là thành phố sôi động nhất của Việt Nam với nền văn hóa phong phú.",
            badge: "Đô thị"
        },
        {
            id: 7,
            name: "Hà Nội",
            region: "Hà Nội",
            coordinates: [21.0285, 105.8542],
            category: "culture",
            image: "https://images.unsplash.com/photo-1583417319070-4a69db38a482?w=600",
            description: "Thủ đô xinh đẹp với những con hẻm cổ kính và hồ Hoàn Kiếm yên bình. Hà Nội mang đậm nét của lịch sử và văn hóa truyền thống.",
            badge: "Thủ đô"
        },
        {
            id: 8,
            name: "Bãi biển Nha Trang",
            region: "Khánh Hòa",
            coordinates: [12.2388, 109.1967],
            category: "beach",
            image: "https://images.unsplash.com/photo-1540611025311-01df3cef54b5?w=600",
            description: "Bãi biển xinh đẹp với cát trắng mịn và nước biển trong xanh. Nha Trang là một trong những điểm đến biển nổi tiếng nhất của Việt Nam.",
            badge: "Biển nắng"
        }
    ];

    let map;
    let markers = [];
    let currentLocation = null;
    let currentFilter = 'all';

    // Initialize map
    function initMap() {
        map = L.map('map').setView([15.5007, 104.869], 6);

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors',
            maxZoom: 19,
            minZoom: 5
        }).addTo(map);

        displayMarkers(locations);
    }

    // Display markers on map
    function displayMarkers(locationsToShow) {
        // Clear existing markers
        markers.forEach(marker => map.removeLayer(marker));
        markers = [];

        locationsToShow.forEach(location => {
            const markerIcon = L.divIcon({
                html: `<div style="background: linear-gradient(135deg, #0EA5E9, #38BDF8); color: white; width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: bold; font-size: 20px; box-shadow: 0 4px 12px rgba(14, 165, 233, 0.3); border: 3px solid white;">
                    <i class="bi bi-geo-alt-fill" style="font-size: 20px;"></i>
                </div>`,
                className: 'location-marker',
                iconSize: [40, 40],
                iconAnchor: [20, 40],
                popupAnchor: [0, -40]
            });

            const marker = L.marker(location.coordinates, { icon: markerIcon })
                .bindPopup(`<strong>${location.name}</strong><br>${location.region}`)
                .addTo(map);

            marker.on('click', () => showLocationInfo(location));
            markers.push(marker);
        });
    }

    // Show location information in panel
    function showLocationInfo(location) {
        currentLocation = location;
        const infoPanelContent = `
            <div class="location-info">
                <img src="${location.image}" alt="${location.name}" class="location-image">
                <div class="location-header">
                    <div class="location-title">
                        <h3>${location.name}</h3>
                        <p><i class="bi bi-geo-alt"></i> ${location.region}</p>
                    </div>
                    <button class="favorite-btn" onclick="toggleFavorite(this)" aria-label="Thêm vào yêu thích">
                        <i class="bi bi-heart"></i>
                    </button>
                </div>
                <div class="location-type-badge">${location.badge}</div>
                <p class="location-description">${location.description}</p>
                <div class="action-buttons">
                    <a href="/Home/LocationDetails?id=${location.id}" class="btn-view-details" target="_blank">
                        <i class="bi bi-eye"></i> Xem chi tiết
                    </a>
                    <button class="btn-add-itinerary" onclick="addToItinerary(${location.id})">
                        <i class="bi bi-calendar-plus"></i> Thêm lịch
                    </button>
                </div>
            </div>
        `;

        const infoPanel = document.querySelector('.info-panel');
        infoPanel.innerHTML = infoPanelContent;

        // Center map on selected location
        map.flyTo(location.coordinates, 10, { duration: 1.5 });
    }

    // Toggle favorite
    function toggleFavorite(btn) {
        btn.classList.toggle('active');
    }

    // Add to itinerary
    function addToItinerary(locationId) {
        alert(`Đã thêm ${currentLocation.name} vào lịch trình!`);
    }

    // Filter locations
    function filterLocations(category) {
        currentFilter = category;
        if (category === 'all') {
            displayMarkers(locations);
        } else {
            const filtered = locations.filter(loc => loc.category === category);
            displayMarkers(filtered);
        }
    }

    // Search locations
    function searchLocations(query) {
        if (!query.trim()) {
            displayMarkers(locations);
            return;
        }

        const searchTerm = query.toLowerCase();
        const results = locations.filter(loc =>
            loc.name.toLowerCase().includes(searchTerm) ||
            loc.region.toLowerCase().includes(searchTerm) ||
            loc.description.toLowerCase().includes(searchTerm)
        );

        if (results.length > 0) {
            displayMarkers(results);
            if (results.length === 1) {
                showLocationInfo(results[0]);
            }
        } else {
            displayMarkers([]);
            alert('Không tìm thấy địa điểm phù hợp!');
        }
    }

    // Event listeners
    document.addEventListener('DOMContentLoaded', function () {
        initMap();

        // Search functionality
        document.getElementById('searchBtn').addEventListener('click', function () {
            const query = document.getElementById('searchInput').value;
            searchLocations(query);
        });

        document.getElementById('searchInput').addEventListener('keypress', function (e) {
            if (e.key === 'Enter') {
                searchLocations(this.value);
            }
        });

        // Filter functionality
        document.querySelectorAll('.filter-btn').forEach(btn => {
            btn.addEventListener('click', function () {
                document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
                this.classList.add('active');
                filterLocations(this.dataset.filter);
            });
        });
    });
</script>
